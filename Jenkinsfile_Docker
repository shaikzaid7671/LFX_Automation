pipeline { 
    agent any 

    environment { 
        DEVICE_IP = "192.168.1.10:5555" 
    } 

    stages { 

        stage('Build Docker Image') { 
            steps { 
                script { 
                    docker.build("appium-epost-test")
                } 
            } 
        } 

        stage('Run Tests') {
            steps {

                // ✅ Remove old container if exists
                bat 'docker rm -f test-container || exit 0'

                // ✅ Run tests (ONLY EPostTest)
                bat '''
                docker run --name test-container ^
                  --add-host=host.docker.internal:host-gateway ^
                  appium-epost-test ^
                  bash -c "mvn clean test -Dtest=EPostTest surefire-report:report"
                '''

                // ✅ Copy reports from container to Jenkins workspace
                bat 'docker cp test-container:/app/target target'
            }
        }
    }

     post {
        always {
            // Publishes the TestNG report
            publishHTML([
            reportDir: 'target/surefire-reports',
            reportFiles: 'surefire-report.html',
            reportName: 'TestNG Reports',
            keepAll: true,
            alwaysLinkToLastBuild: true,
            allowMissing: true
            ])
        }
    }
}
