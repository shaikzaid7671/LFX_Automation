pipeline { 
    agent any 

    environment { 
        DEVICE_IP = "192.168.1.17:5555" 
    } 

    stages { 
        stage('Build Docker Image') { 
            steps { 
                script { 
                    docker.build("appium-epost-test") // ✅ lowercase 
                } 
            } 
        } 

stage('Run Tests') {
    steps {
        bat '''
        docker run --rm --name test-container ^
          --add-host=host.docker.internal:host-gateway ^
          appium-epost-test ^
          bash -c "mvn clean test -Dtest=EPostTest surefire-report:report"
        '''
        }
    }
} 
    
post {
    always {
        publishHTML([
            reportDir: 'target/surefire-reports',
            reportFiles: 'index.html',
            reportName: 'TestNG Surefire Report',
            keepAll: true,
            allowMissing: false,
            alwaysLinkToLastBuild: true
            ])
        }
    }
}
