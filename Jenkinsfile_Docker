pipeline { 
    agent any 

    environment { 
        DEVICE_IP = "192.168.1.17:5555" 
    } 

    stages { 
        stage('Build Docker Image') { 
            steps { 
                script { 
                    docker.build("appium-epost-test") // ✅ lowercase 
                } 
            } 
        } 

        stage('Run Tests') {
    steps {
        bat '''
        docker run --rm ^
        --add-host=host.docker.internal:host-gateway ^
        appium-epost-test bash -c "mvn -Dtest=EPostTest test"
        '''
    }
} 
    }

    post { 
        always { 
            echo "Publishing Test Results..." 
            junit allowEmptyResults: true, testResults: '**/target/surefire-reports/*.xml' 
        } 
    } 
}
